# eBPF kernel config fragment
# Merge into .config later, e.g.:
#   ./scripts/kconfig/merge_config.sh -m .config ebpf.config
#   make olddefconfig

# Core eBPF
CONFIG_BPF=y
CONFIG_BPF_SYSCALL=y
CONFIG_HAVE_EBPF_JIT=y
CONFIG_BPF_JIT=y
CONFIG_CGROUP_BPF=y

# BTF / debug info (requires pahole/dwarves on build host)
CONFIG_DEBUG_INFO=y
CONFIG_DEBUG_INFO_DWARF5=y
CONFIG_DEBUG_INFO_BTF=y
# CONFIG_DEBUG_INFO_NONE is not set
# CONFIG_WERROR is not set

# Tracing (kprobes/uprobes/tracepoints)
CONFIG_FTRACE=y
CONFIG_KPROBE_EVENTS=y
CONFIG_UPROBE_EVENTS=y
CONFIG_HAVE_KPROBES=y
CONFIG_KPROBES=y
CONFIG_BPF_EVENTS=y

# Networking (XDP / TC-BPF / AF_XDP)
CONFIG_NET=y
CONFIG_NET_CLS_BPF=y
CONFIG_NET_ACT_BPF=y
CONFIG_XDP_SOCKETS=y

# Security-hook BPF (LSM-based, e.g. Tetragon/KRSI)
CONFIG_BPF_LSM=y

# Optional hardening: force JIT, no interpreter fallback
# CONFIG_BPF_JIT_ALWAYS_ON=y

# Kernel headers exposed at runtime (useful for bpftool/CO-RE tooling)
CONFIG_IKHEADERS=y
